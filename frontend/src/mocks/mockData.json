  "posts": [
    {
      "_id": "post_001",
      "author_id": "user_org_b_003",
      "content": "Một ngày làm việc hết công suất của cả nhóm tại Bệnh viện Ung bướu! Cảm ơn 20 bạn tình nguyện viên tuyệt vời đã chung tay trao gửi 500 suất cơm nghĩa tình đến tay người bệnh. Những nụ cười và lời cảm ơn từ mọi người chính là động lực lớn nhất của chúng tôi. Hẹn gặp lại các bạn ở các chương trình tới của Green Life nhé!",
      "images": [
